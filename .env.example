# ESPN Fantasy API credentials
# Get these from browser DevTools → Application → Cookies → fantasy.espn.com
ESPN_S2=your_espn_s2_cookie_here
SWID={your-swid-here}

# Target league and season
LEAGUE_ID=your_league_id_here
SEASON=2024

# Optional: controls delay between requests (ms) to avoid rate limits
REQUEST_DELAY_MS=300
